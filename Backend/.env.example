APP_ENV=development

LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.3

PINECONE_API_KEY=
PINECONE_INDEX_NAME=multilingual-text
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

REDIS_CACHE_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=86400
REDIS_CACHE_SIMILARITY_THRESHOLD=0.80
REDIS_CACHE_MAX_CANDIDATES=500

JWT_SECRET_KEY=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@bup.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_DASHBOARD_TOKEN=replace-with-a-long-random-admin-token

REQUIRE_EMAIL_DELIVERY=false
